# =========================
# Python build artifacts
# =========================
__pycache__/      # Compiled Python bytecode cache
*.pyc             # Compiled Python files
*.pyo             # Optimized Python files
*.pyd             # Compiled Python extensions (Windows)
*.pdb             # Debugging files
*.egg-info/       # Metadata about installed Python packages
*.egg             # Python package distribution files

# =========================
# Django / SQLite database
# =========================
db.sqlite3        # Default SQLite database file
*.db              # Any database file
*.sqlite3         # Other SQLite database variations

# =========================
# Uploaded media & static files
# =========================
/PDMS/media/      # Media files uploaded by users (specific to PDMS project)
/static/          # Static files folder (CSS, JS, images)
/staticfiles/     # Django’s collected static files

# =========================
# Django migrations
# (ignore generated files, but keep __init__.py)
# =========================
*/migrations/__pycache__/   # Compiled migration cache
*/migrations/*.py           # Migration scripts generated by Django
!*/migrations/__init__.py   # Keep __init__.py so Django recognizes the folder

# =========================
# Virtual environments
# =========================
venv/             # Virtual environment folder
env/              # Alternative virtual environment folder
.venv/            # Hidden virtual environment folder

# =========================
# Logs & coverage reports
# =========================
*.log             # Log files
coverage/         # Coverage reports folder
htmlcov/          # HTML coverage reports
*.cover           # Coverage data files
*.coverage        # Coverage database file
*.pytest_cache/   # Pytest cache folder

# =========================
# IDE / OS specific files
# =========================
.vscode/          # VS Code project settings
.idea/            # JetBrains IDE settings
.DS_Store         # macOS system file
Thumbs.db         # Windows thumbnail cache

# =========================
# Environment variables
.env
*.nix
.envrc
.direnv

__pycache__
*.sqlite3